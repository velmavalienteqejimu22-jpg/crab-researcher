# ==============================================
# CrabRes - 环境变量配置模板
# 复制此文件为 .env 并填写真实值
# ==============================================

# ---------- 应用基础 ----------
DEBUG=true
API_PREFIX=/api
FRONTEND_URL=https://crab-researcher.vercel.app

# ---------- 数据库 ----------
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:password@host:5432/dbname

# ---------- TokenDance 网关 (OpenAI 兼容，多模型聚合，推荐主力) ----------
# 提供 DeepSeek V4 / Kimi K2.6 / GLM 5/4.7 / Qwen3 / MiniMax M2.7 等
# 配置后自动成为 4 Tier 的首选提供商；未配置时降级到 OpenRouter / Moonshot
TOKENDANCE_API_KEY=sk-your-tokendance-key
TOKENDANCE_BASE_URL=https://tokendance.space/gateway/v1

# ---------- OpenRouter (备用 LLM) ----------
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ---------- 备用 LLM API Keys ----------
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
MOONSHOT_API_KEY=sk-your-moonshot-key

# ---------- 搜索 API ----------
TAVILY_API_KEY=tvly-your-tavily-key
FIRECRAWL_API_KEY=fc-your-firecrawl-key

# ---------- 消息平台（国内）----------
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK
FEISHU_WEBHOOK_SECRET=your-feishu-secret
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# ---------- 消息平台（海外）----------
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- OAuth ----------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ---------- 安全 ----------
JWT_SECRET=generate-a-strong-random-secret-here
API_KEY=generate-another-random-key-here

# ---------- 成本控制 ----------
MONTHLY_BUDGET_PER_USER=100
TOKEN_USAGE_ALERT_THRESHOLD=0.8
